# dev or prod
ENV=dev
# 项目信息
NAME=PEIP AI Hub
DESCRIPTION=PEIP algorithm capability gateway
VERSION=0.1.0
API=/api/v1


# 算法配置文件
ALGORITHMS_FILE=algorithms.yaml


# LLM 模型配置
LLM_ENDPOINT=your_endpoint
LLM_API_KEY=your_api_key
LLM_MODEL=your
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_TIMEOUT_SECONDS=300